components:
  schemas:
    ActionEnum:
      enum:
      - create
      - update
      - delete
      - login
      - logout
      - approve
      - reject
      - verify
      - pay
      - issue
      - lift
      - waive
      - submit
      - vote
      - close
      - publish
      - archive
      - export
      - view
      - other
      type: string
      description: |-
        * `create` - Create
        * `update` - Update
        * `delete` - Delete
        * `login` - Login
        * `logout` - Logout
        * `approve` - Approve
        * `reject` - Reject
        * `verify` - Verify
        * `pay` - Pay
        * `issue` - Issue
        * `lift` - Lift
        * `waive` - Waive
        * `submit` - Submit
        * `vote` - Vote
        * `close` - Close
        * `publish` - Publish
        * `archive` - Archive
        * `export` - Export
        * `view` - View
        * `other` - Other
    Advert:
      type: object
      description: Full advert serializer.
      properties:
        id:
          type: string
          format: uuid
          readOnly: true
        operator:
          type: string
          format: uuid
          readOnly: true
        operator_name:
          type: string
          readOnly: true
        operator_email:
          type: string
          format: email
          readOnly: true
        shop:
          type: string
          format: uuid
        shop_number:
          type: string
          readOnly: true
        headline:
          type: string
          maxLength: 200
        category:
          $ref: '#/components/schemas/Category657Enum'
        category_display:
          type: string
          readOnly: true
        description:
          type: string
        fee:
          type: integer
          readOnly: true
        fee_naira:
          type: string
          readOnly: true
        iscooa_cut:
          type: integer
          readOnly: true
        iscooa_cut_naira:
          type: string
          readOnly: true
        iprolance_cut:
          type: integer
          readOnly: true
        iprolance_cut_naira:
          type: string
          readOnly: true
        status:
          allOf:
          - $ref: '#/components/schemas/Status06fEnum'
          readOnly: true
        reject_reason:
          type: string
          readOnly: true
        reviewed_by:
          type: string
          format: uuid
          readOnly: true
          nullable: true
        reviewed_by_name:
          type: string
          readOnly: true
        reviewed_at:
          type: string
          format: date-time
          readOnly: true
          nullable: true
        is_live:
          type: boolean
          readOnly: true
        live_from:
          type: string
          format: date-time
          readOnly: true
          nullable: true
        expires_at:
          type: string
          format: date-time
          readOnly: true
          nullable: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - category
      - category_display
      - created_at
      - description
      - expires_at
      - fee
      - fee_naira
      - headline
      - id
      - iprolance_cut
      - iprolance_cut_naira
      - is_live
      - iscooa_cut
      - iscooa_cut_naira
      - live_from
      - operator
      - operator_email
      - operator_name
      - reject_reason
      - reviewed_at
      - reviewed_by
      - reviewed_by_name
      - shop
      - shop_number
      - status
      - updated_at
    AdvertCreate:
      type: object
      description: Used by operator to submit a new advert.
      properties:
        shop:
          type: string
          format: uuid
        headline:
          type: string
          maxLength: 200
        category:
          $ref: '#/components/schemas/Category657Enum'
        description:
          type: string
      required:
      - category
      - description
      - headline
      - shop
    AdvertList:
      type: object
      description: Lightweight serializer for listing adverts.
      properties:
        id:
          type: string
          format: uuid
          readOnly: true
        headline:
          type: string
          maxLength: 200
        category:
          $ref: '#/components/schemas/Category657Enum'
        operator_name:
          type: string
          readOnly: true
        shop_number:
          type: string
          readOnly: true
        fee_naira:
          type: string
          readOnly: true
        iscooa_cut_naira:
          type: string
          readOnly: true
        status:
          $ref: '#/components/schemas/Status06fEnum'
        is_live:
          type: boolean
        created_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - category
      - created_at
      - fee_naira
      - headline
      - id
      - iscooa_cut_naira
      - operator_name
      - shop_number
    AdvisoryNote:
      type: object
      properties:
        id:
          type: string
          format: uuid
          readOnly: true
        advisor:
          type: string
          format: uuid
          readOnly: true
        advisor_name:
          type: string
          readOnly: true
        advisor_email:
          type: string
          format: email
          readOnly: true
        note:
          type: string
        submitted_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - advisor
      - advisor_email
      - advisor_name
      - id
      - note
      - submitted_at
    Announcement:
      type: object
      description: Full announcement serializer.
      properties:
        id:
          type: string
          format: uuid
          readOnly: true
        ann_ref:
          type: string
          readOnly: true
        title:
          type: string
          maxLength: 200
        content:
          type: string
        priority:
          $ref: '#/components/schemas/PriorityA85Enum'
        priority_display:
          type: string
          readOnly: true
        category:
          $ref: '#/components/schemas/CategoryDc9Enum'
        category_display:
          type: string
          readOnly: true
        status:
          $ref: '#/components/schemas/AnnouncementStatusEnum'
        status_display:
          type: string
          readOnly: true
        created_by:
          type: string
          format: uuid
          readOnly: true
          nullable: true
        created_by_name:
          type: string
          readOnly: true
        send_email:
          type: boolean
        send_sms:
          type: boolean
        publish_date:
          type: string
          format: date-time
          nullable: true
        expiry_date:
          type: string
          format: date-time
          nullable: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - ann_ref
      - category_display
      - content
      - created_at
      - created_by
      - created_by_name
      - id
      - priority_display
      - status_display
      - title
      - updated_at
    AnnouncementCreate:
      type: object
      description: Used by Secretary General to create an announcement.
      properties:
        title:
          type: string
          maxLength: 200
        content:
          type: string
        priority:
          $ref: '#/components/schemas/PriorityA85Enum'
        category:
          $ref: '#/components/schemas/CategoryDc9Enum'
        send_email:
          type: boolean
        send_sms:
          type: boolean
        publish_date:
          type: string
          format: date-time
          nullable: true
        expiry_date:
          type: string
          format: date-time
          nullable: true
      required:
      - content
      - title
    AnnouncementStatusEnum:
      enum:
      - draft
      - published
      - expired
      type: string
      description: |-
        * `draft` - Draft
        * `published` - Published
        * `expired` - Expired
    Association:
      type: object
      properties:
        id:
          type: string
          format: uuid
          readOnly: true
        name:
          type: string
          maxLength: 200
        slug:
          type: string
          maxLength: 50
          pattern: ^[-a-zA-Z0-9_]+$
        short_name:
          type: string
          maxLength: 50
        location:
          type: string
          maxLength: 200
        is_active:
          type: boolean
        launched_at:
          type: string
          format: date
          nullable: true
        config:
          allOf:
          - $ref: '#/components/schemas/AssociationConfig'
          readOnly: true
        created_at:
          type: string
          format: date-time
          readOnly: true
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - config
      - created_at
      - id
      - name
      - short_name
      - slug
      - updated_at
    AssociationConfig:
      type: object
      properties:
        id:
          type: string
          format: uuid
          readOnly: true
        member_prefix:
          type: string
          maxLength: 20
        subscription_rate:
          type: integer
          maximum: 9223372036854775807
          minimum: -9223372036854775808
          format: int64
        subscription_rate_naira:
          type: string
          readOnly: true
        bot_threshold:
          type: integer
          maximum: 9223372036854775807
          minimum: -9223372036854775808
          format: int64
        bot_threshold_naira:
          type: string
          readOnly: true
        association_share:
          type: integer
          maximum: 2147483647
          minimum: -2147483648
        platform_share:
          type: integer
          maximum: 2147483647
          minimum: -2147483648
        logo_url:
          type: string
          format: uri
          maxLength: 200
        primary_color:
          type: string
          maxLength: 10
        secondary_color:
          type: string
          maxLength: 10
        contact_email:
          type: string
          format: email
          maxLength: 254
        contact_phone:
          type: string
          maxLength: 20
        website:
          type: string
          format: uri
          maxLength: 200
        footer_text:
          type: string
          maxLength: 200
        wallet_provider:
          type: string
          maxLength: 100
        wallet_provider_short:
          type: string
          maxLength: 30
        toilet_association_share:
          type: integer
          maximum: 2147483647
          minimum: -2147483648
        updated_at:
          type: string
          format: date-time
          readOnly: true
      required:
      - bot_threshold_naira
      - id
      - subscription_rate_naira
      - updated_at
    AssociationCreate:
      type: object
      description: Used by Super Admin to create a new association.
      properties:
        name:
          type: string
          maxLength: 200
        slug:
          type: string
          maxLength: 50
          pattern: ^[-a-zA-Z0-9_]+$
        short_name:
          type: string
          maxLength: 50
        location:
          type: string
          maxLength: 200
        launched_at:
          type: string
          format: date
          nullable: true
        member_prefix:
          type: string
          writeOnly: true
        subscription_rate:
          type: integer
          writeOnly: true
          default: 100000
        bot_threshold:
          type: integer
          writeOnly: true
          default: 500000000
        association_share:
          type: integer
          writeOnly: true
          default: 20
        platform_share:
          type: integer
          writeOnly: true
          default: 80
        logo_url:
          type: string
          format: uri
          writeOnly: true
        primary_color:
          type: string
          writeOnly: true
          default: '#1a3a5c'
        secondary_color:
          type: string
          writeOnly: true
