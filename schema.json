openapi: 3.0.3
info:
  title: ISCOOA Facitech API
  version: 1.0.0
  description: "\nISCOOA Facitech is the official digital management and billing platform\nfor
    ISCOOA — Ikota Shopping Complex Owners and Operators Association, VGC, Lagos.\n\nDeveloped
    by Iprolance LLC. Powered by Cool Microfinance Bank.\n\n## Authentication\nAll
    endpoints except `/api/v1/auth/login/` and `/api/v1/auth/register/`\nrequire a
    Bearer JWT token in the Authorization header.\n\n**Format:** `Authorization: Bearer
    <your_access_token>`\n\n## Roles\nThe platform has 6 roles — each with a different
    set of accessible endpoints:\n- `op` — Operator (shop owner)\n- `is` — ISCOOA
    Executive (President, Treasurer, Secretary General etc)\n- `bot` — Board of Trustees\n-
    `adv` — Advisor\n- `sa` — Iprolance Super Admin\n\n## Amounts\nAll monetary amounts
    are stored and transmitted in **kobo** (integer).\nDivide by 100 to get Naira.
    Every response includes a companion `_naira` field for display.\n\n## Support\nContact:
    Iprolance LLC\n    "
paths:
  /api/v1/auth/login/:
    post:
      operationId: v1_auth_login_create
      description: |-
        POST /api/v1/auth/login/
        Returns access + refresh tokens with user data.
        Blocks inactive accounts.
        Rate limited to 10 attempts per minute per IP.
        Account locked after 5 failed attempts (django-axes).
      tags:
      - Auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CustomTokenObtainPair'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/CustomTokenObtainPair'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/CustomTokenObtainPair'
        required: true
      security:
      - BearerAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CustomTokenObtainPair'
          description: ''
  /api/v1/auth/refresh/:
    post:
      operationId: v1_auth_refresh_create
      description: |-
        Takes a refresh type JSON web token and returns an access type JSON web
        token if the refresh token is valid.
      tags:
      - v1
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TokenRefresh'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/TokenRefresh'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/TokenRefresh'
        required: true
      security:
      - BearerAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TokenRefresh'
          description: ''
  /api/v1/auth/register/:
    post:
      operationId: v1_auth_register_create
      description: |-
        POST /api/v1/auth/register/
        PUBLIC endpoint — operators only.
        Rate limited to 5 registrations per hour per IP.
      tags:
      - Auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/OperatorRegister'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/OperatorRegister'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/OperatorRegister'
        required: true
      security:
      - jwtAuth: []
      - BearerAuth: []
      - {}
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/OperatorRegister'
          description: ''
  /api/v1/auth/create-account/:
    post:
      operationId: v1_auth_create_account_create
      description: |-
        POST /api/v1/auth/create-account/
        PROTECTED — President or Super Admin only.
        Creates Exco, BOT, Advisor or Super Admin accounts.
        Operators must use the public register endpoint.
      tags:
      - Auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PrivilegedAccountCreate'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PrivilegedAccountCreate'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PrivilegedAccountCreate'
        required: true
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PrivilegedAccountCreate'
          description: ''
  /api/v1/auth/me/:
    get:
      operationId: v1_auth_me_retrieve
      description: |-
        GET /api/v1/auth/me/
        Returns the currently logged-in user profile.
        Also returns KYC status for operators.
      tags:
      - Auth
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/auth/change-password/:
    post:
      operationId: v1_auth_change_password_create
      description: |-
        POST /api/v1/auth/change-password/
        Any authenticated user can change their own password.
      tags:
      - Auth
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/auth/users/:
    get:
      operationId: v1_auth_users_list
      description: |-
        GET /api/v1/auth/users/
        Super Admin only — lists all users.
        Filter by ?role=op|is|bot|adv|sa
        Filter by ?is_active=true|false
      parameters:
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      tags:
      - Auth
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedUserList'
          description: ''
  /api/v1/auth/users/{id}/deactivate/:
    post:
      operationId: v1_auth_users_deactivate_create
      description: |-
        POST /api/v1/auth/users/<id>/deactivate/
        President or Super Admin deactivates a user account.
        Deactivated accounts cannot login.
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Auth
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/auth/users/{id}/reactivate/:
    post:
      operationId: v1_auth_users_reactivate_create
      description: |-
        POST /api/v1/auth/users/<id>/reactivate/
        President or Super Admin reactivates a deactivated account.
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Auth
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/overview/operator/:
    get:
      operationId: v1_overview_operator_retrieve
      description: |-
        GET /api/v1/overview/operator/
        Operator home dashboard.
        Aggregates shops, bills, wallet and subscription data.
      tags:
      - Overview
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/overview/exec/:
    get:
      operationId: v1_overview_exec_retrieve
      description: |-
        GET /api/v1/overview/exec/
        ISCOOA Executive home dashboard.
        Aggregates KYC queue, adverts, disputes,
        revenue and pending actions.
      tags:
      - Overview
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/overview/bot/:
    get:
      operationId: v1_overview_bot_retrieve
      description: |-
        GET /api/v1/overview/bot/
        Board of Trustees home dashboard.
      tags:
      - Overview
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/overview/advisor/:
    get:
      operationId: v1_overview_advisor_retrieve
      description: |-
        GET /api/v1/overview/advisor/
        Advisor home dashboard.
      tags:
      - Overview
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/overview/superadmin/:
    get:
      operationId: v1_overview_superadmin_retrieve
      description: |-
        GET /api/v1/overview/superadmin/
        Iprolance Super Admin platform overview.
      tags:
      - Overview
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/kyc/start/:
    post:
      operationId: v1_kyc_start_create
      description: |-
        POST /api/v1/kyc/start/
        Operator starts a new KYC application.
        Creates the root KYCApplication record.
        Only one application per operator allowed.
      tags:
      - KYC
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/kyc/my-application/:
    get:
      operationId: v1_kyc_my_application_retrieve
      description: |-
        GET /api/v1/kyc/my-application/
        Operator retrieves their own full KYC record.
      tags:
      - KYC
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/kyc/step/personal/:
    post:
      operationId: v1_kyc_step_personal_create
      description: |-
        POST /api/v1/kyc/step/personal/
        Operator submits Step 1 — Personal Identity.
      tags:
      - KYC
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/kyc/step/business/:
    post:
      operationId: v1_kyc_step_business_create
      description: |-
        POST /api/v1/kyc/step/business/
        Operator submits Step 2 — Business Profile.
      tags:
      - KYC
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/kyc/step/shops/:
    post:
      operationId: v1_kyc_step_shops_create
      description: |-
        POST /api/v1/kyc/step/shops/
        Operator submits Step 3 — Shops.
        Accepts a list of shop records. Replaces existing shops for this application.
      tags:
      - KYC
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/kyc/step/iscooa-standing/:
    post:
      operationId: v1_kyc_step_iscooa_standing_create
      description: POST /api/v1/kyc/step/iscooa-standing/ — Step 4
      tags:
      - KYC
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/kyc/step/staff/:
    post:
      operationId: v1_kyc_step_staff_create
      description: POST /api/v1/kyc/step/staff/ — Step 5
      tags:
      - KYC
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/kyc/step/next-of-kin/:
    post:
      operationId: v1_kyc_step_next_of_kin_create
      description: POST /api/v1/kyc/step/next-of-kin/ — Step 6
      tags:
      - KYC
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/kyc/step/guarantor/:
    post:
      operationId: v1_kyc_step_guarantor_create
      description: POST /api/v1/kyc/step/guarantor/ — Step 7
      tags:
      - KYC
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/kyc/step/finance/:
    post:
      operationId: v1_kyc_step_finance_create
      description: POST /api/v1/kyc/step/finance/ — Step 8
      tags:
      - KYC
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/kyc/step/emergency-contact/:
    post:
      operationId: v1_kyc_step_emergency_contact_create
      description: POST /api/v1/kyc/step/emergency-contact/ — Step 9
      tags:
      - KYC
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/kyc/step/documents/:
    post:
      operationId: v1_kyc_step_documents_create
      description: POST /api/v1/kyc/step/documents/ — Step 10
      tags:
      - KYC
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/kyc/step/declaration/:
    post:
      operationId: v1_kyc_step_declaration_create
      description: POST /api/v1/kyc/step/declaration/ — Step 11 (final submission)
      tags:
      - KYC
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/kyc/upload/passport-photo/:
    post:
      operationId: v1_kyc_upload_passport_photo_create
      description: |-
        POST /api/v1/kyc/upload/passport-photo/
        Operator uploads their passport photo.
        Accepts: JPEG, PNG. Max: 5MB.
        Blocked after KYC approval.
        Old file deleted when replaced.
      tags:
      - KYC
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/kyc/upload/id-file/:
    post:
      operationId: v1_kyc_upload_id_file_create
      description: |-
        POST /api/v1/kyc/upload/id-file/
        Operator uploads their government ID.
        Accepts: JPEG, PNG, PDF. Max: 5MB.
        Blocked after KYC approval.
        Old file deleted when replaced.
      tags:
      - KYC
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/kyc/upload/documents/:
    post:
      operationId: v1_kyc_upload_documents_create
      description: |-
        POST /api/v1/kyc/upload/documents/
        Operator uploads all KYC documents in one request.
        Each field is optional — upload one or more at a time.
        Blocked after KYC approval.
        Old files deleted when replaced.

        Fields accepted:
            passport_photo  — JPEG/PNG image
            gov_id          — JPEG/PNG/PDF
            cac_certificate — JPEG/PNG/PDF
            tenancy_lease   — JPEG/PNG/PDF
            shop_photo      — JPEG/PNG image
      tags:
      - KYC
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/kyc/upload/shop-photo/{shop_id}/:
    post:
      operationId: v1_kyc_upload_shop_photo_create
      description: |-
        POST /api/v1/kyc/upload/shop-photo/<shop_id>/
        Operator uploads a photo for a specific KYC shop record.
        Accepts: JPEG, PNG. Max: 5MB.
        Blocked after KYC approval.
        Old file deleted when replaced.
      parameters:
      - in: path
        name: shop_id
        schema:
          type: integer
        required: true
      tags:
      - KYC
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/kyc/upload/status/:
    get:
      operationId: v1_kyc_upload_status_retrieve
      description: |-
        GET /api/v1/kyc/upload/status/
        Operator checks which documents have been uploaded.
        Shows a checklist of uploaded vs missing documents.
        Also shows whether uploads are currently allowed.
      tags:
      - KYC
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/kyc/queue/:
    get:
      operationId: v1_kyc_queue_list
      description: |-
        GET /api/v1/kyc/queue/
        ISCOOA Executive sees all KYC applications.
        Filter by status using ?status=submitted|docs_requested|approved|rejected
      parameters:
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      tags:
      - KYC
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedKYCApplicationListList'
          description: ''
  /api/v1/kyc/{id}/:
    get:
      operationId: v1_kyc_retrieve
      description: |-
        GET /api/v1/kyc/<id>/
        ISCOOA Executive views full KYC record.
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - KYC
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/KYCApplication'
          description: ''
  /api/v1/kyc/{id}/approve/:
    post:
      operationId: v1_kyc_approve_create
      description: |-
        POST /api/v1/kyc/<id>/approve/
        ISCOOA Executive approves a KYC application.
        Auto-assigns a member number.
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - KYC
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/kyc/{id}/request-docs/:
    post:
      operationId: v1_kyc_request_docs_create
      description: |-
        POST /api/v1/kyc/<id>/request-docs/
        ISCOOA Executive requests additional documents.
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - KYC
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/kyc/{id}/reject/:
    post:
      operationId: v1_kyc_reject_create
      description: |-
        POST /api/v1/kyc/<id>/reject/
        ISCOOA Executive rejects a KYC application.
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - KYC
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          description: No response body
  /api/v1/shops/my-shops/:
    get:
      operationId: v1_shops_my_shops_list
      description: |-
        GET /api/v1/shops/my-shops/
        Operator sees all their own shops.
      parameters:
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      tags:
      - Shop
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedShopList'
          description: ''
  /api/v1/shops/create/:
    post:
      operationId: v1_shops_create_create
      description: |-
        POST /api/v1/shops/create/
        Operator registers a new shop.
      tags:
      - Shop
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ShopCreate'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/ShopCreate'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/ShopCreate'
        required: true
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ShopCreate'
          description: ''
  /api/v1/shops/{id}/:
    get:
      operationId: v1_shops_retrieve
      description: |-
        GET  /api/v1/shops/<id>/
        PUT  /api/v1/shops/<id>/
        Operator views or updates their own shop.
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Shop
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Shop'
          description: ''
    put:
      operationId: v1_shops_update
      description: |-
        GET  /api/v1/shops/<id>/
        PUT  /api/v1/shops/<id>/
        Operator views or updates their own shop.
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Shop
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ShopCreate'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/ShopCreate'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/ShopCreate'
        required: true
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ShopCreate'
          description: ''
    patch:
      operationId: v1_shops_partial_update
      description: |-
        GET  /api/v1/shops/<id>/
        PUT  /api/v1/shops/<id>/
        Operator views or updates their own shop.
      parameters:
      - in: path
        name: id
        schema:
          type: string
          format: uuid
        required: true
      tags:
      - Shop
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedShopCreate'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedShopCreate'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedShopCreate'
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ShopCreate'
          description: ''
  /api/v1/shops/my-staff/:
    get:
      operationId: v1_shops_my_staff_list
      description: |-
        GET /api/v1/shops/my-staff/
        Operator sees all their registered staff.
      parameters:
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      tags:
      - Shop
      security:
      - jwtAuth: []
      - BearerAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedStaffMemberList'
          description: ''
  /api/v1/shops/my-staff/add/:
    post:
      operationId: v1_shops_my_staff_add_create
      description: |-
        POST /api/v1/shops/my-staff/add/
        Operator registers a new staff member.
        Max 5 staff enforced here.
      tags:
      - Shop
      security:
      - jwtAuth: []
      - BearerAuth: []
