# ─── CORE ─────────────────────────────────────────────────────────────────────
SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── DATABASE (PostgreSQL / Supabase) ─────────────────────────────────────────
DB_NAME=iscooa_facitech
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# ─── JWT ──────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── COOL MFB API (Production) ────────────────────────────────────────────────
COOLMFB_API_KEY=
COOLMFB_API_SECRET=
COOLMFB_BASE_URL=

# ─── PAYSTACK (Production) ────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# ─── TERMII SMS (Production) ──────────────────────────────────────────────────
TERMII_API_KEY=
TERMII_SENDER_ID=ISCOOA

# ─── EMAIL / POSTMARK (Production) ────────────────────────────────────────────
POSTMARK_API_KEY=
DEFAULT_FROM_EMAIL=noreply@iscooa.ng

# ─── FILE STORAGE (Production) ────────────────────────────────────────────────
# Leave blank for local storage during development
# Set to 'cloudinary' or 's3' for production
FILE_STORAGE_BACKEND=
CLOUDINARY_URL=